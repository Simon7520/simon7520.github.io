{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "chokidar": "^3.6.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "chokidar"
      ],
      "allowAny": [
        "chokidar"
      ]
    }
  },
  "scripts": {
    "start": "pnpm run dev",
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo generate && hexo deploy",
    "server": "hexo server",
    "dev": "hexo server -p 80"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "hexo": "^8.1.1",
    "hexo-abbrlink": "^2.2.1",
    "hexo-deployer-git": "^4.0.0",
    "hexo-generator-archive": "^1.0.0",
    "hexo-generator-category": "^1.0.0",
    "hexo-generator-index": "^2.0.0",
    "hexo-generator-searchdb": "^1.4.0",
    "hexo-generator-tag": "^1.0.0",
    "hexo-renderer-ejs": "^1.0.0",
    "hexo-renderer-marked": "^4.0.0",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^2.1.0",
    "hexo-server": "^2.0.0",
    "hexo-theme-landscape": "^0.0.3",
    "hexo-word-counter": "0.0.3",
    "prism-themes": "^1.8.0"
  }
}